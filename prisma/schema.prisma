generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  tickets      Ticket[]
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  capacity    Int
  createdAt   DateTime @default(now())
  tickets     Ticket[]
}

model Ticket {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
}
